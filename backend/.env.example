# Embedding
EMBEDDING_PROVIDER=api   # api | local
EMBEDDING_API_KEY=api-key-here-if-needed
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=1536

# Generation
LLM_API_KEY=api-key-here-if-needed
LLM_MODEL=deepseek-v3
LLM_BASE_URL=https://api.deepseek.com
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=recall

# SQLite
SQLITE_PATH=data/recall.db

# Vector search
VECTOR_SCORE_THRESHOLD=0.35

# Reranker
RERANKER_ALPHA=0.6
RERANKER_BETA=0.2
RERANKER_GAMMA=0.2
RERANKER_S_BASE=24.0
RERANKER_TAG_FALLBACK=0.5
RERANKER_SCORE_THRESHOLD=0.60

# Logging
LOG_LEVEL=INFO

# File management
UPLOAD_FILE_DIR=data/files